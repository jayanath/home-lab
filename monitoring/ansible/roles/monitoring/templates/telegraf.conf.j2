# Telegraf configuration — managed by Ansible, do not edit manually.
# Receives IPFIX/NetFlow from UCG Max on UDP {{ telegraf_netflow_port }}
# and writes to InfluxDB v2.

[agent]
  interval = "10s"
  round_interval = true
  metric_batch_size = 5000
  metric_buffer_limit = 50000
  collection_jitter = "2s"
  flush_interval = "10s"
  flush_jitter = "5s"
  precision = ""
  hostname = "monitoring"
  omit_hostname = false

# ── Input: NetFlow / IPFIX ────────────────────────────────────────────────────
# Receives IPFIX from UCG Max (configured in CyberSecure → Traffic Logging)
[[inputs.netflow]]
  ## Address to listen for NetFlow/IPFIX packets from UCG Max
  service_address = "udp://:{{ telegraf_netflow_port }}"

  ## Protocol auto-detection handles IPFIX, NetFlow v9, and v5
  protocol = "IPFIX"

# ── Input: NUT UPS (via exec + upsc) ─────────────────────────────────────────
# inputs.nut plugin not available in this Telegraf build — uses exec workaround
[[inputs.exec]]
  commands = ["/etc/telegraf/nut-metrics.sh {{ nut_server_ip }} {{ nut_ups_name }}"]
  interval = "30s"
  timeout = "10s"
  data_format = "influx"
  name_override = "nut"

# ── Output: InfluxDB v2 (NetFlow) ─────────────────────────────────────────────
[[outputs.influxdb_v2]]
  urls = ["http://127.0.0.1:{{ influxdb_port }}"]
  token = "{{ monitoring_influxdb_operator_token }}"
  organization = "{{ influxdb_org }}"
  bucket = "{{ influxdb_netflow_bucket }}"
  timeout = "5s"
  [outputs.influxdb_v2.namepass]
    measurement = ["netflow"]

# ── Output: InfluxDB v2 (NUT) ─────────────────────────────────────────────────
[[outputs.influxdb_v2]]
  urls = ["http://127.0.0.1:{{ influxdb_port }}"]
  token = "{{ monitoring_influxdb_operator_token }}"
  organization = "{{ influxdb_org }}"
  bucket = "{{ influxdb_nut_bucket }}"
  timeout = "5s"
  [outputs.influxdb_v2.namepass]
    measurement = ["nut"]
