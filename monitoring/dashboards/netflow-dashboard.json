          "query": "ucgIP = \"192.168.193.1\"\n\nfrom(bucket: \"netflow\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"netflow\")\n  |> filter(fn: (r) => r._field == \"src\" or r._field == \"dst\" or r._field == \"dst_port\" or r._field == \"in_bytes\")\n  |> pivot(rowKey: [\"_time\", \"host\", \"source\", \"version\"], columnKey: [\"_field\"], valueColumn: \"_value\")\n  |> filter(fn: (r) => r.dst_port == 53 and r.dst != ucgIP)\n  |> group(columns: [\"src\", \"dst\"])\n  |> reduce(\n      fn: (r, accumulator) => ({flows: accumulator.flows + 1, bytes: accumulator.bytes + r.in_bytes}),\n      identity: {flows: 0, bytes: 0}\n  )\n  |> sort(columns: [\"flows\"], desc: true)\n  |> rename(columns: {src: \"Source\", dst: \"DNS Server\", flows: \"Flows\", bytes: \"Bytes\"})",
